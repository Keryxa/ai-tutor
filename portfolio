<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes, maximum-scale=2.0">
  <title>Креативный редактор · Портфолио карточек</title>
  <!-- Font Awesome 6 для иконок -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      width: 100%;
      min-height: 100vh;
      background: linear-gradient(145deg, #0f0f1a 0%, #1a1a2e 100%);
      font-family: 'Segoe UI', 'Inter', system-ui, -apple-system, sans-serif;
      color: #f0f0f0;
      display: flex;
      flex-direction: column;
      align-items: center;
      overflow-x: hidden;
    }

    /* Основной контейнер на всю ширину */
    .site-wrapper {
      width: 100%;
      max-width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    /* ----- АНИМИРОВАННЫЕ КНОПКИ С ГРАДИЕНТОМ (ВЕРХ) ----- */
    .nav-bar {
      width: 100%;
      padding: 1.8rem 2rem 1rem;
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 2rem;
      background: rgba(10, 10, 20, 0.75);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      position: sticky;
      top: 0;
      z-index: 50;
    }

    .gradient-btn {
      padding: 0.9rem 2.8rem;
      border: none;
      border-radius: 60px;
      font-weight: 700;
      font-size: 1.3rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      background: linear-gradient(135deg, #ff6b9d, #c44dff, #6b7bff);
      background-size: 250% 250%;
      color: white;
      cursor: pointer;
      box-shadow: 0 10px 25px rgba(180, 80, 255, 0.4);
      transition: all 0.3s ease;
      animation: gradientShift 4s ease infinite;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .gradient-btn i {
      font-size: 1.2rem;
      transition: transform 0.2s;
    }

    .gradient-btn:hover {
      transform: translateY(-3px);
      box-shadow: 0 18px 35px rgba(200, 100, 255, 0.6);
      animation: gradientShift 2s ease infinite;
    }

    .gradient-btn:hover i {
      transform: scale(1.2);
    }

    @keyframes gradientShift {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    /* ----- ОБЩИЕ СЕКЦИИ ----- */
    section {
      width: 100%;
      padding: 3rem 2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .container {
      width: 100%;
      max-width: 1400px;
    }

    h2 {
      font-size: 2.8rem;
      font-weight: 700;
      margin-bottom: 2.5rem;
      background: linear-gradient(to right, #ffb3d9, #c79bff, #9bb3ff);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      text-align: center;
      letter-spacing: -0.02em;
    }

    /* ----- ИНФО ОБО МНЕ (КРАТКО) ----- */
    .about-me {
      background: rgba(255, 255, 255, 0.03);
      margin: 1rem 0 2rem;
      border-radius: 80px;
      padding: 2.5rem 3rem;
      backdrop-filter: blur(5px);
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
      gap: 3rem;
      border: 1px solid rgba(255,255,255,0.08);
    }

    .stat-highlight {
      display: flex;
      flex-wrap: wrap;
      gap: 3rem;
      justify-content: center;
    }

    .stat-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      font-weight: 600;
    }

    .stat-number {
      font-size: 3rem;
      font-weight: 800;
      background: linear-gradient(135deg, #f9a8d4, #b084f5);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .stat-label {
      font-size: 1rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #ccccdd;
    }

    /* ----- ПОРТФОЛИО: КАРТОЧКИ ДО И ПОСЛЕ ----- */
    .portfolio-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 2.5rem;
      justify-content: center;
    }

    .card-pair {
      background: rgba(20, 20, 35, 0.7);
      backdrop-filter: blur(12px);
      border-radius: 2.5rem;
      padding: 1.8rem;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
      gap: 1.8rem;
      border: 1px solid rgba(255, 255, 255, 0.1);
      box-shadow: 0 25px 40px -15px rgba(0,0,0,0.6);
      transition: transform 0.25s ease;
    }

    .card-pair:hover {
      transform: scale(1.02);
    }

    .marketplace-card {
      width: 260px;
      background: #ffffff;
      border-radius: 1.8rem;
      padding: 1.2rem;
      color: #1e1e2f;
      box-shadow: 0 12px 28px rgba(0,0,0,0.5);
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      font-family: 'Inter', sans-serif;
    }

    .card-img {
      width: 100%;
      height: 160px;
      background: #e9e9f0;
      border-radius: 1rem;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 1rem;
      color: #4a4a6a;
      background-size: cover;
      background-position: center;
      position: relative;
      overflow: hidden;
    }

    .badge {
      background: #ff5e7e;
      color: white;
      font-size: 0.7rem;
      padding: 0.2rem 0.7rem;
      border-radius: 30px;
      font-weight: 700;
    }

    .price {
      font-weight: 800;
      font-size: 1.4rem;
      color: #13101c;
    }

    .old-price {
      text-decoration: line-through;
      color: #9e9eb0;
      font-size: 0.9rem;
    }

    .title {
      font-weight: 700;
      font-size: 1rem;
    }

    .before-label, .after-label {
      font-weight: 700;
      margin-top: 0.3rem;
      font-size: 0.8rem;
      letter-spacing: 0.05em;
      color: #b5b5e0;
    }

    .mock-bg-before {
      background: linear-gradient(135deg, #d9d9e6, #b0b0c0);
      background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" fill="%239999bb"><rect width="100" height="100" fill="%23d4d4e2"/><circle cx="30" cy="40" r="15" fill="%23bcbcd6"/><circle cx="70" cy="60" r="18" fill="%23a0a0cc"/></svg>');
    }

    .mock-bg-after {
      background: radial-gradient(circle at 20% 30%, #ffe6f0, #fadaff);
      background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><linearGradient id="g" x1="0%25" y1="0%25" x2="100%25" y2="100%25"><stop offset="0%25" stop-color="%23ffb7c5"/><stop offset="100%25" stop-color="%23d9b3ff"/></linearGradient></defs><rect width="100" height="100" fill="url(%23g)"/><circle cx="50" cy="45" r="22" fill="%23ffffffaa"/><circle cx="25" cy="70" r="10" fill="%23ffe5b4"/></svg>');
      background-size: cover;
      filter: drop-shadow(0 4px 8px rgba(230,120,200,0.4));
    }

    /* ----- ОТЗЫВЫ ----- */
    .reviews-container {
      display: flex;
      flex-wrap: wrap;
      gap: 1.5rem;
      justify-content: center;
      margin-bottom: 2.5rem;
    }

    .review-card {
      background: rgba(30, 30, 45, 0.8);
      backdrop-filter: blur(12px);
      border-radius: 2rem;
      padding: 1.8rem;
      max-width: 300px;
      flex: 1 1 250px;
      border: 1px solid rgba(255,255,255,0.15);
      box-shadow: 0 20px 30px -10px black;
    }

    .stars {
      color: #ffb84d;
      margin-bottom: 0.8rem;
    }

    .review-text {
      font-style: italic;
      margin: 0.8rem 0;
    }

    .review-author {
      font-weight: 700;
      color: #c9b0ff;
    }

    /* Форма комментария с паролем */
    .comment-box {
      background: rgba(20, 20, 35, 0.8);
      border-radius: 2.5rem;
      padding: 2rem 2.5rem;
      width: 100%;
      max-width: 650px;
      backdrop-filter: blur(15px);
      display: flex;
      flex-direction: column;
      gap: 1rem;
      border: 1px solid rgba(255,255,255,0.2);
      margin-top: 1rem;
    }

    .comment-box input, .comment-box textarea {
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 2rem;
      padding: 0.9rem 1.4rem;
      color: white;
      font-size: 1rem;
      outline: none;
      transition: 0.2s;
    }

    .comment-box input:focus, .comment-box textarea:focus {
      border-color: #c44dff;
      background: rgba(255,255,255,0.12);
    }

    .password-row {
      display: flex;
      gap: 1rem;
      align-items: center;
      flex-wrap: wrap;
    }

    .submit-btn {
      background: linear-gradient(135deg, #c44dff, #6b7bff);
      border: none;
      border-radius: 3rem;
      padding: 0.9rem 2.2rem;
      font-weight: 700;
      color: white;
      cursor: pointer;
      transition: 0.3s;
      box-shadow: 0 8px 20px rgba(150,70,255,0.5);
    }

    .submit-btn:hover {
      transform: scale(1.04);
      box-shadow: 0 12px 28px #b573ff;
    }

    .hidden {
      display: none;
    }

    .message-status {
      font-size: 0.9rem;
      color: #ffb3d9;
    }

    /* ----- МОДАЛЬНОЕ ОКНО КОНТАКТОВ ----- */
    .modal {
      display: none;
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0,0,0,0.8);
      backdrop-filter: blur(10px);
      align-items: center;
      justify-content: center;
      z-index: 100;
    }

    .modal-content {
      background: rgba(25, 25, 40, 0.95);
      border-radius: 3rem;
      padding: 2.8rem;
      max-width: 400px;
      width: 90%;
      text-align: center;
      border: 1px solid rgba(255,255,255,0.25);
      box-shadow: 0 30px 50px #00000070;
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    .contact-link {
      background: rgba(255,255,255,0.08);
      padding: 1rem 1.8rem;
      border-radius: 4rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      font-size: 1.3rem;
      font-weight: 600;
      color: white;
      text-decoration: none;
      transition: 0.3s;
    }

    .contact-link i {
      font-size: 2rem;
      color: #c084fc;
    }

    .contact-link:hover {
      background: rgba(255,255,255,0.18);
    }

    .close-modal {
      margin-top: 0.5rem;
      background: transparent;
      border: 1px solid #ffffff55;
      color: white;
      padding: 0.5rem 2rem;
      border-radius: 3rem;
      cursor: pointer;
    }
  </style>
</head>
<body>
<div class="site-wrapper">
  <!-- Верхние кнопки -->
  <div class="nav-bar">
    <button class="gradient-btn" onclick="scrollToSection('portfolio')"><i class="fas fa-images"></i> Портфолио</button>
    <button class="gradient-btn" onclick="scrollToSection('reviews')"><i class="fas fa-star"></i> Отзывы</button>
    <button class="gradient-btn" onclick="openContactModal()"><i class="fas fa-address-book"></i> Контакты</button>
  </div>

  <!-- Краткая информация -->
  <section style="padding-top: 2rem;">
    <div class="about-me container">
      <div class="stat-highlight">
        <div class="stat-item"><span class="stat-number">5+</span><span class="stat-label">лет опыта</span></div>
        <div class="stat-item"><span class="stat-number">1000+</span><span class="stat-label">успешных заказов</span></div>
        <div class="stat-item"><span class="stat-number">98%</span><span class="stat-label">довольных клиентов</span></div>
        <div class="stat-item"><span class="stat-number">ТОП</span><span class="stat-label">креативный редактор</span></div>
      </div>
    </div>
  </section>

  <!-- ПОРТФОЛИО -->
  <section id="portfolio">
    <h2>✨ До / После обработки</h2>
    <div class="container portfolio-grid">
      <!-- Карточка 1 -->
      <div class="card-pair">
        <div>
          <div class="before-label">📸 ДО</div>
          <div class="marketplace-card">
            <div class="card-img mock-bg-before"></div>
            <span class="badge">-15%</span>
            <div class="title">Крем для лица</div>
            <div><span class="old-price">2 490 ₽</span> <span class="price">2 116 ₽</span></div>
          </div>
        </div>
        <div>
          <div class="after-label">✨ ПОСЛЕ</div>
          <div class="marketplace-card">
            <div class="card-img mock-bg-after"></div>
            <span class="badge" style="background:#b347ea;">Хит продаж</span>
            <div class="title">Сияние кожи</div>
            <div><span class="old-price">2 490 ₽</span> <span class="price">1 999 ₽</span></div>
          </div>
        </div>
      </div>
      <!-- Карточка 2 -->
      <div class="card-pair">
        <div>
          <div class="before-label">📸 ДО</div>
          <div class="marketplace-card">
            <div class="card-img mock-bg-before" style="background:#c8c8dd;"></div>
            <span class="badge">Скидка</span>
            <div class="title">Наушники</div>
            <div><span class="old-price">5 990 ₽</span> <span class="price">4 790 ₽</span></div>
          </div>
        </div>
        <div>
          <div class="after-label">✨ ПОСЛЕ</div>
          <div class="marketplace-card">
            <div class="card-img mock-bg-after" style="background:radial-gradient(circle at 70% 20%, #ffe5f0, #cdaeff);"></div>
            <span class="badge" style="background:#6b5ce7;">Тренд</span>
            <div class="title">Premium Sound</div>
            <div><span class="old-price">5 990 ₽</span> <span class="price">4 490 ₽</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ОТЗЫВЫ -->
  <section id="reviews">
    <h2>💬 Отзывы клиентов</h2>
    <div class="container reviews-container" id="reviewsList">
      <!-- Отзывы будут заполнены через JS, но несколько жестко заданы -->
    </div>

    <!-- Форма с паролем -->
    <div class="comment-box">
      <div style="font-weight:600; font-size:1.2rem;">Оставить отзыв</div>
      <div class="password-row">
        <input type="password" id="passInput" placeholder="Пароль (135710)" value="">
        <input type="text" id="authorInput" placeholder="Ваше имя" style="flex:1;">
      </div>
      <textarea id="reviewTextInput" rows="3" placeholder="Текст отзыва..."></textarea>
      <div style="display: flex; justify-content: space-between; align-items: center;">
        <span class="message-status" id="statusMsg"></span>
        <button class="submit-btn" onclick="submitReview()"><i class="fas fa-paper-plane"></i> Отправить</button>
      </div>
      <div style="font-size:0.8rem; color:#aaa;">Пароль для публикации: 135710</div>
    </div>
  </section>

  <!-- Модальное окно контактов -->
  <div id="contactModal" class="modal">
    <div class="modal-content">
      <h2 style="color:white; margin-bottom:0.2rem;">Связь со мной</h2>
      <a href="https://t.me/casper_lider" target="_blank" class="contact-link">
        <i class="fab fa-telegram-plane"></i> @casper_lider
      </a>
      <a href="mailto:arestov03900@gmail.com" class="contact-link">
        <i class="fas fa-envelope"></i> arestov03900@gmail.com
      </a>
      <button class="close-modal" onclick="closeContactModal()">Закрыть</button>
    </div>
  </div>
</div>

<script>
  // Массив фейковых отзывов (изначальные)
  const initialReviews = [
    { author: "Анна К.", text: "Лучший редактор! Карточки стали продаваться в 3 раза лучше. Очень креативно!", stars: 5 },
    { author: "Максим Б.", text: "Заказал обработку 50 карточек – всё сдано раньше срока. Профи!", stars: 5 },
    { author: "Елена В.", text: "До и после – небо и земля. Рекомендую всем селлерам.", stars: 5 },
    { author: "Артём С.", text: "Крутой подход, грамотный дизайн, улучшил конверсию.", stars: 5 },
    { author: "Ольга М.", text: "Сотрудничаем больше года. Всегда на связи, правки моментальные.", stars: 5 },
    { author: "Дмитрий П.", text: "Очень доволен! Карточки выглядят дорого и стильно.", stars: 5 }
  ];

  const reviewsContainer = document.getElementById('reviewsList');
  const password = "135710";

  function renderStars(count) {
    return '★'.repeat(count) + '☆'.repeat(5-count);
  }

  function displayReviews(reviewsArray) {
    if (!reviewsContainer) return;
    reviewsContainer.innerHTML = '';
    reviewsArray.forEach(r => {
      const card = document.createElement('div');
      card.className = 'review-card';
      card.innerHTML = `
        <div class="stars">${renderStars(r.stars)}</div>
        <div class="review-text">“${r.text}”</div>
        <div class="review-author">— ${r.author}</div>
      `;
      reviewsContainer.appendChild(card);
    });
  }

  // Инициализация отзывов
  displayReviews(initialReviews);

  // Функция отправки комментария
  function submitReview() {
    const pass = document.getElementById('passInput').value.trim();
    const author = document.getElementById('authorInput').value.trim();
    const text = document.getElementById('reviewTextInput').value.trim();
    const status = document.getElementById('statusMsg');

    if (pass !== password) {
      status.textContent = '❌ Неверный пароль';
      return;
    }
    if (!author || !text) {
      status.textContent = '⚠️ Заполните имя и текст';
      return;
    }

    // Добавляем новый отзыв в начало массива и перерисовываем
    const newReview = { author: author, text: text, stars: 5 };
    // Обновляем отображение: собираем текущие отзывы из DOM? проще хранить массив.
    // Пересоздадим массив из initialReviews + пользовательские (сохраним в session?)
    // Для удобства просто добавим в начало текущего контейнера.
    const currentReviews = [];
    // Соберём существующие отзывы из DOM
    document.querySelectorAll('.review-card').forEach(card => {
      const authEl = card.querySelector('.review-author')?.textContent?.replace('— ','');
      const textEl = card.querySelector('.review-text')?.textContent?.replace(/[“”]/g,'');
      if(authEl && textEl) currentReviews.push({author: authEl, text: textEl, stars:5});
    });
    currentReviews.unshift(newReview);
    displayReviews(currentReviews);

    // Очистка полей
    document.getElementById('authorInput').value = '';
    document.getElementById('reviewTextInput').value = '';
    document.getElementById('passInput').value = '';
    status.textContent = '✅ Отзыв опубликован!';
    setTimeout(() => { status.textContent = ''; }, 3000);
  }

  // Скролл к секциям
  function scrollToSection(id) {
    const el = document.getElementById(id);
    if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // Модальное окно контактов
  function openContactModal() {
    document.getElementById('contactModal').style.display = 'flex';
  }
  function closeContactModal() {
    document.getElementById('contactModal').style.display = 'none';
  }
  // Закрытие по клику вне модального окна
  window.onclick = function(event) {
    const modal = document.getElementById('contactModal');
    if (event.target === modal) {
      modal.style.display = 'none';
    }
  }

  // Дополнительно: если нажата кнопка портфолио/отзывы сверху
  document.querySelectorAll('.gradient-btn').forEach(btn => {
    // Уже обработано через onclick в html, но можно оставить
  });
</script>
</body>
</html>
